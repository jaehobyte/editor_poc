<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        108x108 viewport with content centered inside the 72x72 safe zone
        (offset 18 to 90).

        Design: two overlapping rounded "photo frames".
          - Lower-left frame  → white outline = original input
          - Upper-right frame → warm gradient fill = reference look applied
        Suggests style transfer between two photos.
    -->

    <!-- Lower-left frame: white outline only -->
    <path
        android:pathData="M34,40 L66,40 A8,8 0 0,1 74,48 L74,80 A8,8 0 0,1 66,88 L34,88 A8,8 0 0,1 26,80 L26,48 A8,8 0 0,1 34,40 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

    <!-- Upper-right frame: warm color gradient fill -->
    <path android:pathData="M52,24 L84,24 A8,8 0 0,1 92,32 L92,64 A8,8 0 0,1 84,72 L52,72 A8,8 0 0,1 44,64 L44,32 A8,8 0 0,1 52,24 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="20"
                android:endX="92"
                android:endY="72"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD27A"/>
                <item android:offset="0.5" android:color="#FF6B6B"/>
                <item android:offset="1.0" android:color="#B26BFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle inner accent on top frame: small white "spectrum" mark -->
    <path
        android:pathData="M54,56 L82,56"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeAlpha="0.85"/>
    <path
        android:pathData="M54,62 L70,62"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeAlpha="0.55"/>
</vector>
